{
  "servers": {
    "gopls": {
      "command": "gopls",
      "args": ["serve"],
      "languages": ["go", "go.mod", "go.sum"],
      "initializationOptions": {
        "usePlaceholders": true,
        "staticcheck": true,
        "gofumpt": true,
        "analyses": {
          "unusedparams": true,
          "shadow": true,
          "nilness": true,
          "unusedwrite": true
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    }
  }
}
